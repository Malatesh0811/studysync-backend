# Copy this file to .env and fill in your values.

# PostgreSQL connection string
DATABASE_URL=postgresql://studysync:studysync@localhost:5432/studysync

# S3 / AWS
AWS_BUCKET_NAME=studysync-files
AWS_REGION=us-east-1
# Leave these empty to use instance-profile / env-var credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# How long presigned URLs are valid (seconds)
PRESIGNED_URL_EXPIRY=3600
